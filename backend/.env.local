NODE_ENV=development
PORT=10003
DATABASE_URL=postgresql://postgres:postgres@localhost:10001/socratic
REDIS_URL=redis://localhost:10002
JWT_SECRET=local-dev-jwt-secret-key-32chars
JWT_REFRESH_SECRET=local-dev-refresh-secret-key
