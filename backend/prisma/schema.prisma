generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  STUDENT
  TEACHER
  ADMIN
}

enum SessionStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MasteryLevel {
  BEGINNER
  UNDERSTANDING
  PROFICIENT
  MASTERY
}

enum DocumentType {
  BOOK
  MATERIAL
}

enum DocumentStatus {
  PROCESSING
  READY
  ERROR
}

enum ReadingSessionStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum BookMessageRole {
  USER
  ASSISTANT
}

enum Level {
  ELEMENTARY
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  UNIVERSITY
  GRADUATE
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String?
  name            String
  role            Role             @default(STUDENT)
  preferences     Json             @default("{}")
  sessions        Session[]
  learningRecords LearningRecord[]
  documents       Document[]
  readingSessions BookReadingSession[]
  userPreference  UserPreference?
  learningPlans   LearningPlan[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Session {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  subject   String
  topic     String?
  title     String
  status    SessionStatus @default(ACTIVE)
  messages  Message[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   Session     @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now())
}

model LearningRecord {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  concept       String
  masteryLevel  MasteryLevel @default(BEGINNER)
  lastPracticed DateTime     @default(now())

  @@unique([userId, concept])
}

model Subject {
  id             String           @id @default(uuid())
  name           String           @unique
  description    String
  knowledgePoints KnowledgePoint[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model KnowledgePoint {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([subjectId, name])
}

model Document {
  id              String               @id @default(uuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  type            DocumentType
  status          DocumentStatus       @default(PROCESSING)
  title           String
  author          String?
  description     String?
  originalName    String
  storagePath     String
  mimeType        String
  fileSize        Int
  coverUrl        String?
  errorMessage    String?
  processedAt     DateTime?
  chapters        Chapter[]
  chunks          DocumentChunk[]
  readingSessions BookReadingSession[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId, type])
  @@index([status])
}

model Chapter {
  id                String               @id @default(uuid())
  documentId        String
  document          Document             @relation(fields: [documentId], references: [id])
  title             String
  content           String               @db.Text
  orderIndex        Int
  startPage         Int?
  endPage           Int?
  chunks            DocumentChunk[]
  activeInSessions  BookReadingSession[] @relation("CurrentChapter")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([documentId, orderIndex])
}

model DocumentChunk {
  id         String                     @id @default(uuid())
  documentId String
  document   Document                   @relation(fields: [documentId], references: [id])
  chapterId  String?
  chapter    Chapter?                   @relation(fields: [chapterId], references: [id])
  content    String                     @db.Text
  orderIndex Int
  tokenCount Int?
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                   @default(now())

  @@index([documentId])
  @@index([chapterId])
}

model BookReadingSession {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id])
  documentId       String
  document         Document             @relation(fields: [documentId], references: [id])
  currentChapterId String?
  currentChapter   Chapter?             @relation("CurrentChapter", fields: [currentChapterId], references: [id])
  status           ReadingSessionStatus @default(ACTIVE)
  progress         Float                @default(0)
  messages         BookMessage[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([userId, status])
}

model BookMessage {
  id        String          @id @default(uuid())
  sessionId String
  session   BookReadingSession @relation(fields: [sessionId], references: [id])
  role      BookMessageRole
  content   String          @db.Text
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([sessionId, createdAt])
}

enum LearningPlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model LearningPlan {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  title       String
  description String?
  subject     String
  targetDate  DateTime?
  status      LearningPlanStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, status])
}

model UserPreference {
  id        String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  level      Level    @default(HIGH_SCHOOL)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
